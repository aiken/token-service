{
  "name": "token-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",

    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:deploy": "npm run pages:build && wrangler pages deploy dist",
    "pages:dev": "npx @cloudflare/next-on-pages && wrangler pages dev dist",

    "========== 数据库管理脚本 ==========": "",

    "db:migrate": "wrangler d1 execute token-service-db --file=./migrations/001_init.sql",
    "db:migrate:dev": "wrangler d1 execute token-service-db-dev --local --file=./migrations/001_init.sql",
    "db:migrate:all": "npm run db:migrate:001 && npm run db:migrate:002 && npm run db:migrate:003",
    "db:migrate:all:dev": "npm run db:migrate:001:dev && npm run db:migrate:002:dev && npm run db:migrate:003:dev",

    "db:migrate:001": "wrangler d1 execute token-service-db --file=./migrations/001_init.sql",
    "db:migrate:001:dev": "wrangler d1 execute token-service-db-dev --local --file=./migrations/001_init.sql",
    "db:migrate:002": "wrangler d1 execute token-service-db --file=./migrations/002_add_providers.sql",
    "db:migrate:002:dev": "wrangler d1 execute token-service-db-dev --local --file=./migrations/002_add_providers.sql",
    "db:migrate:003": "wrangler d1 execute token-service-db --file=./migrations/003_add_company_fields.sql",
    "db:migrate:003:dev": "wrangler d1 execute token-service-db-dev --local --file=./migrations/003_add_company_fields.sql",

    "db:seed": "wrangler d1 execute token-service-db --file=./migrations/seed.sql",
    "db:seed:dev": "wrangler d1 execute token-service-db-dev --local --file=./migrations/seed.sql",

    "db:reset:dev": "npm run db:clean:dev && npm run db:migrate:all:dev && npm run db:seed:dev",
    "db:clean:dev": "node scripts/clean-db.js",

    "db:export:dev": "node scripts/export-db.js",
    "db:import:dev": "node scripts/import-fixtures.js",

    "dev:cf": "npm run build && wrangler pages dev dist --compatibility-date=2024-01-01 --d1=DB"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "next": "15.2.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^3.2.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9",
    "eslint-config-next": "15.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.12.0"
  }
}

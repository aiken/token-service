# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# wrangler
.wrangler/tmp/

# build output (for Cloudflare Pages, dist is built fresh each time)
/dist/_next/static/chunks/*.js
/dist/_next/static/chunks/*.css
/dist/_next/static/media/*.woff2
/dist/_next/static/media/*.ico
/dist/_next/static/*/_buildManifest.js
/dist/_next/static/*/_ssgManifest.js
/dist/_next/static/*/_clientMiddlewareManifest.js
/dist/**/*.txt
/dist/__next.*
